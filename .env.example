# =============================================================================
# Art AI – Environment Variables
# Copy this file to `.env` and fill in real values.
# NEVER commit the real .env file.
# =============================================================================

# --- Firebase (client config) ---
# Get these from Firebase Console → Project Settings → Your apps → SDK setup
FIREBASE_API_KEY=AIzaSyXXXXXXXXXXXXXXXXXXXX
FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
FIREBASE_PROJECT_ID=your-project
FIREBASE_STORAGE_BUCKET=your-project.appspot.com
FIREBASE_MESSAGING_SENDER_ID=000000000000
FIREBASE_APP_ID=1:000000000000:android:xxxxxxxxxxxxxxxxxxxxxx

# iOS – separate app id if you have one
FIREBASE_IOS_APP_ID=1:000000000000:ios:xxxxxxxxxxxxxxxxxxxxxx

# --- Gemini API key (client-side fallback only; preferred path is Cloud Functions) ---
GEMINI_API_KEY=

# --- Razorpay ---
# Public key (Key ID) – safe to bundle in app
RAZORPAY_KEY_ID=rzp_test_XXXXXXXXXXXXXX
# Used only inside Cloud Functions (never bundle in app)
# Set with: firebase functions:secrets:set RAZORPAY_KEY_SECRET
RAZORPAY_KEY_SECRET=

# --- Misc ---
APP_NAME=Art AI
SUPPORT_EMAIL=support@artai.app
